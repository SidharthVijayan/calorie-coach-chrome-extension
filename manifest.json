{
  "manifest_version": 3,
  "name": "Calorie Coach",
  "version": "2.2.0",
  "description": "Gamified calorie tracking with AI-style coaching and cloud sync",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Calorie Coach"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "oauth2": {
    "client_id": "840998585030-8023ao8gd3of8j1gt9kh9c7tmv1f03jp.apps.googleusercontent.com",
    "scopes": [
      "profile",
      "email"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["sounds/*"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
