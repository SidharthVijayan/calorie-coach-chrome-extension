{
  "manifest_version": 3,
  "name": "Calorie Coach",
  "version": "2.2.0",
  "description": "Gamified calorie tracking with premium UI, login, and cloud sync",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Calorie Coach"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],

  "host_permissions": [
    "https://*/*",
    "http://*/*"
  ],

  "oauth2": {
    "client_id": "PASTE_YOUR_GOOGLE_CLIENT_ID_HERE",
    "scopes": [
      "profile",
      "email"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [
    {
      "resources": ["sounds/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
