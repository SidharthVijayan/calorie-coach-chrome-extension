{
  "manifest_version": 3,
  "name": "Calorie Coach",
  "version": "2.2.0",
  "description": "Gamified calorie tracking with Google login and smart coaching",

  "action": {
    "default_popup": "popup.html",
    "default_title": "Calorie Coach"
  },

  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "identity"
  ],

  "host_permissions": [
    "https://www.googleapis.com/*"
  ],

  "oauth2": {
    "client_id": "840998585030-8023ao8gd3of8j1gt9kh9c7tmv1f03jp.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/userinfo.email"
    ]
  },

  "background": {
    "service_worker": "background.js"
  }
}
